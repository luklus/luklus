    "nuxt": "^4.4.8",
    "tailwindcss": "^4.3.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nuxt/a11y": "1.0.0-alpha.1",
    "@nuxt/content": "^3.15.0",
    "@nuxt/eslint": "^1.16.0",
    "@nuxt/hints": "^1.1.3",
    "@nuxt/image": "^2.0.0",
    "@nuxt/test-utils": "^4.0.3",
    "@nuxtjs/i18n": "^10.4.1",
    "@nuxtjs/seo": "^5.3.2",
    "@vite-pwa/nuxt": "^1.1.1",
