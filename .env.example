# Copy this file to `.env` for local development and set values as needed.
# On Vercel, configure these under Settings > Environment Variables.
# Nuxt maps NUXT_* variables onto runtimeConfig automatically.

# Public site URL — used for canonical links, sitemap, robots, SEO.
NUXT_PUBLIC_SITE_URL=https://luklus.me

# Example private runtime value (server-only). Uncomment and rename as needed.
# NUXT_API_SECRET=

# Vercel Analytics / Speed Insights are configured in the Vercel dashboard,
# no env var required.
